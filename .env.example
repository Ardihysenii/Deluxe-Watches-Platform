# Copy to .env and fill in values from Neon Console:
# https://console.neon.tech -> alfa-accessories -> Connection details
#
# Or run: neonctl connection-string --project-id cold-resonance-47334897
# Convert postgresql://user:pass@host/neondb?sslmode=require to the variables below.

NEON_DATABASE_URL=jdbc:postgresql://ep-xxxx.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_USER=neondb_owner
NEON_DATABASE_PASSWORD=your_neon_password

# PowerShell - load .env then run:
# Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim(), 'Process') } }
# .\mvnw.cmd spring-boot:run

# Optional email for order confirmations
SPRING_MAIL_USERNAME=your@gmail.com
SPRING_MAIL_PASSWORD=your_app_password

# EmailJS (order thank-you + admin notification)
EMAILJS_SERVICE_ID=service_1c7ketd
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_CUSTOMER_TEMPLATE_ID=template_fodcn56
EMAILJS_ADMIN_TEMPLATE_ID=template_oxas6dc
DELUXE_ADMIN_EMAIL=your@gmail.com
DELUXE_SITE_BASE_URL=https://your-production-domain.com
# Required for watch images in emails (Gmail cannot load localhost URLs)
DELUXE_EMAIL_IMAGE_BASE_URL=https://your-production-domain.com
